---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Chaos Theory — Math Explorations | Hayaan Dangra"
  description="Interactive visualization of the logistic map showing how simple equations produce chaotic behavior."
>
  <section class="demo-page section">
    <div class="container">
      <h1>Chaos Theory: The Logistic Map</h1>

      <div class="explanation">
        <p>The logistic map is one of the simplest equations that produces chaos:</p>
        <div class="equation">
          x<sub>n+1</sub> = r · x<sub>n</sub> · (1 - x<sub>n</sub>)
        </div>
        <p>It models population growth with limited resources. The parameter <strong>r</strong> controls the growth rate. Watch what happens as you increase r — the system goes from stable to periodic to completely chaotic.</p>
        <p>This is why weather is hard to predict. Tiny changes in initial conditions create wildly different outcomes.</p>
      </div>

      <div class="demo-container">
        <h2>Bifurcation Diagram</h2>
        <canvas id="chaosCanvas"></canvas>

        <div class="controls">
          <div class="control-group">
            <label for="rSlider">
              Growth Rate (r): <span id="rValue">2.80</span>
            </label>
            <input type="range" id="rSlider" min="2.4" max="4.0" step="0.01" value="2.8">
          </div>

          <div class="button-group">
            <button id="resetBtn">Reset</button>
            <button id="animateBtn">Animate r</button>
          </div>
        </div>

        <h3>Time Series at r = <span id="rValueTime">2.80</span></h3>
        <canvas id="timeCanvas"></canvas>
      </div>

      <div class="why-matters">
        <h2>Why This Matters</h2>
        <p>The logistic map shows that deterministic systems (no randomness!) can produce behavior that looks completely random. This discovery in the 1970s launched the field of chaos theory.</p>
        <p>The bifurcation diagram above is one of the most famous images in mathematics. Notice the period-doubling cascade — the system splits from 1 value to 2, then 4, then 8... then suddenly chaos.</p>
      </div>

      <nav class="demo-nav">
        <a href="/math-explorations">← Back to Math Explorations</a>
        <a href="/math-explorations/primes">Next: Prime Spirals →</a>
      </nav>
    </div>
  </section>
</Layout>

<style>
  .demo-page {
    padding: var(--space-xl) 0 var(--space-3xl);
  }

  h1 {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  h3 {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
    font-size: 1.25rem;
  }

  .explanation {
    max-width: 800px;
    margin: 0 auto var(--space-2xl);
    background-color: var(--light-gray);
    padding: var(--space-lg);
    border-radius: 8px;
    border-left: 4px solid var(--blue);
  }

  .equation {
    font-family: 'Courier New', monospace;
    font-size: 1.5rem;
    text-align: center;
    padding: var(--space-md);
    background-color: var(--white);
    border-radius: 4px;
    margin: var(--space-md) 0;
  }

  .demo-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  canvas {
    width: 100%;
    border: 1px solid var(--mid-gray);
    border-radius: 4px;
    background-color: var(--white);
    display: block;
  }

  #chaosCanvas {
    height: 400px;
  }

  #timeCanvas {
    height: 250px;
  }

  .controls {
    margin: var(--space-lg) 0;
    padding: var(--space-md);
    background-color: var(--light-gray);
    border-radius: 8px;
  }

  .control-group {
    margin-bottom: var(--space-md);
  }

  .control-group:last-of-type {
    margin-bottom: 0;
  }

  label {
    display: block;
    margin-bottom: var(--space-xs);
    font-weight: 500;
    color: var(--charcoal);
  }

  #rValue, #rValueTime {
    color: var(--blue);
    font-weight: 700;
  }

  input[type="range"] {
    width: 100%;
    height: 8px;
    border-radius: 4px;
    background: var(--mid-gray);
    outline: none;
    -webkit-appearance: none;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--blue);
    cursor: pointer;
  }

  input[type="range"]::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--blue);
    cursor: pointer;
    border: none;
  }

  .button-group {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  button {
    min-width: 120px;
    min-height: 44px;
  }

  .why-matters {
    max-width: 800px;
    margin: var(--space-2xl) auto;
    padding: var(--space-lg);
    background-color: var(--light-gray);
    border-radius: 8px;
    border-left: 4px solid var(--orange);
  }

  .demo-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--mid-gray);
    flex-wrap: wrap;
  }

  .demo-nav a {
    font-weight: 500;
  }

  @media (max-width: 768px) {
    #chaosCanvas {
      height: 300px;
    }

    #timeCanvas {
      height: 200px;
    }

    .demo-nav {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script>
  const chaosCanvas = document.getElementById('chaosCanvas') as HTMLCanvasElement;
  const timeCanvas = document.getElementById('timeCanvas') as HTMLCanvasElement;
  const rSlider = document.getElementById('rSlider') as HTMLInputElement;
  const rValue = document.getElementById('rValue') as HTMLSpanElement;
  const rValueTime = document.getElementById('rValueTime') as HTMLSpanElement;
  const resetBtn = document.getElementById('resetBtn') as HTMLButtonElement;
  const animateBtn = document.getElementById('animateBtn') as HTMLButtonElement;

  let animationFrame: number | null = null;
  let isAnimating = false;

  function setupCanvas(canvas: HTMLCanvasElement) {
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    const ctx = canvas.getContext('2d')!;
    ctx.scale(dpr, dpr);
    return { ctx, width: rect.width, height: rect.height };
  }

  function logistic(x: number, r: number): number {
    return r * x * (1 - x);
  }

  function drawBifurcationDiagram(currentR: number) {
    const { ctx, width, height } = setupCanvas(chaosCanvas);

    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, width, height);

    // Draw axes
    ctx.strokeStyle = '#ECF0F1';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, height);
    ctx.lineTo(width, height);
    ctx.moveTo(0, 0);
    ctx.lineTo(0, height);
    ctx.stroke();

    // Draw bifurcation diagram
    const rMin = 2.4;
    const rMax = 4.0;
    const steps = Math.floor(width / 2);

    ctx.fillStyle = 'rgba(52, 152, 219, 0.3)';

    for (let i = 0; i < steps; i++) {
      const r = rMin + (i / steps) * (rMax - rMin);
      let x = 0.5;

      // Skip transient
      for (let j = 0; j < 200; j++) {
        x = logistic(x, r);
      }

      // Plot points
      for (let j = 0; j < 100; j++) {
        x = logistic(x, r);
        const px = (r - rMin) / (rMax - rMin) * width;
        const py = height - (x * height);
        ctx.fillRect(px, py, 2, 2);
      }
    }

    // Draw current r indicator
    const px = (currentR - rMin) / (rMax - rMin) * width;
    ctx.strokeStyle = '#E67E22';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(px, 0);
    ctx.lineTo(px, height);
    ctx.stroke();

    // Labels
    ctx.fillStyle = '#2C3E50';
    ctx.font = '13px DM Sans';
    ctx.fillText('r = 2.4', 10, height - 10);
    ctx.fillText('r = 4.0', width - 50, height - 10);
    ctx.fillText('x', 10, 20);
  }

  function drawTimeSeries(r: number) {
    const { ctx, width, height } = setupCanvas(timeCanvas);

    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, width, height);

    // Draw axes
    ctx.strokeStyle = '#ECF0F1';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, height);
    ctx.lineTo(width, height);
    ctx.moveTo(0, 0);
    ctx.lineTo(0, height);
    ctx.stroke();

    // Generate time series
    const iterations = 100;
    let x = 0.5;
    const points: number[] = [];

    for (let i = 0; i < iterations; i++) {
      points.push(x);
      x = logistic(x, r);
    }

    // Draw line
    ctx.strokeStyle = '#3498DB';
    ctx.lineWidth = 2;
    ctx.beginPath();

    points.forEach((val, i) => {
      const px = (i / (iterations - 1)) * width;
      const py = height - (val * height);

      if (i === 0) {
        ctx.moveTo(px, py);
      } else {
        ctx.lineTo(px, py);
      }
    });

    ctx.stroke();

    // Labels
    ctx.fillStyle = '#2C3E50';
    ctx.font = '13px DM Sans';
    ctx.fillText('Iteration 0', 10, height - 10);
    ctx.fillText('100', width - 30, height - 10);
    ctx.fillText('x value', 10, 20);
  }

  function updateVisualization() {
    const r = parseFloat(rSlider.value);
    rValue.textContent = r.toFixed(2);
    rValueTime.textContent = r.toFixed(2);
    drawBifurcationDiagram(r);
    drawTimeSeries(r);
  }

  function animate() {
    if (!isAnimating) return;

    let r = parseFloat(rSlider.value);
    r += 0.005;

    if (r > 4.0) {
      r = 2.4;
      isAnimating = false;
      animateBtn.textContent = 'Animate r';
      return;
    }

    rSlider.value = r.toString();
    updateVisualization();

    animationFrame = requestAnimationFrame(animate);
  }

  rSlider.addEventListener('input', updateVisualization);

  resetBtn.addEventListener('click', () => {
    isAnimating = false;
    if (animationFrame) {
      cancelAnimationFrame(animationFrame);
    }
    rSlider.value = '2.8';
    animateBtn.textContent = 'Animate r';
    updateVisualization();
  });

  animateBtn.addEventListener('click', () => {
    if (isAnimating) {
      isAnimating = false;
      if (animationFrame) {
        cancelAnimationFrame(animationFrame);
      }
      animateBtn.textContent = 'Animate r';
    } else {
      isAnimating = true;
      rSlider.value = '2.4';
      animateBtn.textContent = 'Stop Animation';
      animate();
    }
  });

  window.addEventListener('resize', updateVisualization);

  // Initial draw
  updateVisualization();
</script>
