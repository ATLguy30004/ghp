<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p class="copyright">&copy; 2026 Hayaan Dangra</p>
      <!-- TODO: Replace # with Hayaan's actual profile URLs when created -->
      <div class="social-links">
        <a href="#" target="_blank" rel="noopener noreferrer">Twitter</a>
        <a href="#" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="#" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--charcoal);
    color: var(--white);
    padding: var(--space-xl) 0;
    margin-top: var(--space-3xl);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
    text-align: center;
  }

  .copyright {
    margin: 0;
    font-size: 0.9rem;
  }

  .social-links {
    display: flex;
    gap: var(--space-lg);
  }

  .social-links a {
    color: var(--white);
    text-decoration: none;
    transition: color 0.2s ease;
    font-weight: 500;
  }

  .social-links a:hover {
    color: var(--blue);
  }

  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
