---
---

<section class="hero">
  <div class="container">
    <h1 class="hero-title">MATH IS HOW I MAKE SENSE OF THE WORLD</h1>
    <p class="hero-subtitle">CFO financial modeling. Cybersecurity competitions. Interactive math demos. Everything I build connects back to logic, patterns, and proof.</p>

    <div class="stats">
      <div class="stat-pill">
        <span class="stat-number">790</span>
        <span class="stat-label">Math SAT</span>
      </div>
      <div class="stat-pill">
        <span class="stat-number">4.3</span>
        <span class="stat-label">GPA</span>
      </div>
      <div class="stat-pill">
        <span class="stat-number">Network+</span>
        <span class="stat-label">CompTIA Certified</span>
      </div>
    </div>

    <a href="#projects" class="cta-button">See My Work ↓</a>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-3xl) 0;
    text-align: center;
    background: linear-gradient(180deg, var(--light-gray) 0%, var(--white) 100%);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1.1;
    color: var(--charcoal);
    margin-bottom: var(--space-md);
    letter-spacing: 1px;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--charcoal);
    margin-bottom: var(--space-xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0.9;
  }

  .stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    align-items: center;
  }

  .stat-pill {
    background-color: var(--white);
    border: 2px solid var(--blue);
    border-radius: 50px;
    padding: var(--space-sm) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 200px;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--blue);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--charcoal);
    margin-top: 4px;
  }

  .cta-button {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 500;
    padding: var(--space-md) var(--space-xl);
    background-color: var(--blue);
    color: var(--white);
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    background-color: var(--orange);
    color: var(--white);
    transform: translateY(-2px);
  }

  @media (min-width: 480px) {
    .stats {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding: var(--space-3xl) 0 calc(var(--space-3xl) + var(--space-xl));
    }

    .hero-title {
      font-size: 3.5rem;
      margin-bottom: var(--space-lg);
    }

    .hero-subtitle {
      font-size: 1.25rem;
      margin-bottom: var(--space-2xl);
    }

    .stats {
      margin-bottom: var(--space-2xl);
    }

    .stat-pill {
      min-width: 220px;
    }

    .stat-number {
      font-size: 2rem;
    }

    .stat-label {
      font-size: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 4.5rem;
    }
  }
</style>
